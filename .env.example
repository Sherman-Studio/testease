# Test Ease — local environment. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored. Never commit real secrets.

# ── PRIMARY credential ────────────────────────────────────────────────
# The flat-price Claude Code subscription OAuth token. The harness runs
# the `claude` CLI on YOUR Claude Code Max subscription (flat price, not
# per-token API billing) and scrubs ANTHROPIC_API_KEY so the CLI uses
# this token. Mint one with:  claude setup-token
# ToS note: using subscription tokens for automated/headless runs is a
# gray area; the sanctioned commercial path is the `api` backend (set
# QA_LLM_BACKEND=api and supply ANTHROPIC_API_KEY instead).
CLAUDE_CODE_OAUTH_TOKEN=

# LLM backend: claude-code (subscription token, default) | api (ANTHROPIC_API_KEY).
QA_LLM_BACKEND=claude-code

# ── Target under test ─────────────────────────────────────────────────
# The Site Model is keyed by (tenant, target). QA_TARGET_ID names the
# site this run is about; QA_WEB_BASE_URL is where the personas browse.
QA_TARGET_ID=
QA_WEB_BASE_URL=

# Logical DB name in the local Atlas deployment (default: testease).
QA_STORE_DB=testease

# ── Optional: embeddings ──────────────────────────────────────────────
# Default embeddings are LOCAL (fastembed / BAAI/bge-small-en-v1.5, 384-d,
# in-process, no key) — Anthropic has no embeddings API. Provide a key
# ONLY if you build with the qa-store[vector] extra AND wire the OpenAI
# provider (text-embedding-3-small, 1536-d). Today the provider is chosen
# in code, not by this env (see CLAUDE.md "What's left").
OPENAI_API_KEY=

# ── Optional: GitHub issue filing ─────────────────────────────────────
# Findings log internally by default. Set these to file GitHub issues.
GITHUB_TOKEN=
GITHUB_REPO=
