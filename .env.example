# Test Ease — local environment. Copy to `.env` and fill in.
#   cp .env.example .env
# `.env` is gitignored. Never commit real secrets.

# ── PRIMARY credential ────────────────────────────────────────────────
# The flat-price Claude Code subscription OAuth token. The harness runs
# the `claude` CLI on YOUR Claude Code Max subscription (flat price, not
# per-token API billing) and scrubs ANTHROPIC_API_KEY so the CLI uses
# this token. Mint one with:  claude setup-token
# ToS note: using subscription tokens for automated/headless runs is a
# gray area; the sanctioned commercial path is the `api` backend (set
# QA_LLM_BACKEND=api and supply ANTHROPIC_API_KEY instead).
CLAUDE_CODE_OAUTH_TOKEN=

# LLM backend: claude-code (subscription token, default) | api (ANTHROPIC_API_KEY).
QA_LLM_BACKEND=claude-code

# Per-token billing path: supply this and set QA_LLM_BACKEND=api.
ANTHROPIC_API_KEY=

# Both of the above can also be set in the UI (Settings → Claude credentials);
# a UI-supplied token is stored in the vault and takes precedence over these.
# Encryption at rest for vaulted secrets — a Fernet key (`Fernet.generate_key()`).
# Unset → the vault falls back to plaintext-at-rest with a warning (dev only).
QA_CREDENTIAL_KEY=

# ── Target under test ─────────────────────────────────────────────────
# The Site Model is keyed by (tenant, target). QA_TARGET_ID names the
# site this run is about; QA_WEB_BASE_URL is where the personas browse.
QA_TARGET_ID=
QA_WEB_BASE_URL=

# Logical DB name in the local Atlas deployment (default: testease).
QA_STORE_DB=testease

# ── Optional: embeddings ──────────────────────────────────────────────
# Embedding provider selector. Anthropic has no embeddings API, so the
# DEFAULT is LOCAL and key-free: fastembed / BAAI/bge-small-en-v1.5 (384-d,
# in-process). Options:
#   local  (default) — no key; the Site Model vector indexes are sized 384-d.
#   openai           — text-embedding-3-small (1536-d); needs OPENAI_API_KEY
#                      and the qa-store[vector] extra. The boot-time index
#                      init sizes the vector indexes to 1536-d to match.
#   mock             — deterministic, dev/tests only.
# NB: switching providers after the vector indexes already exist means
# dropping + recreating them (different numDimensions) and re-embedding.
QA_EMBEDDING_PROVIDER=local
OPENAI_API_KEY=

# ── Optional: GitHub issue filing ─────────────────────────────────────
# Findings log internally by default. Set these to file GitHub issues.
GITHUB_TOKEN=
GITHUB_REPO=
