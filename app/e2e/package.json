{
  "name": "test-ease-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright smoke tests for Test Ease — self-contained, intercepts /api/* so no real backend is required.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "install-browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0"
  }
}
